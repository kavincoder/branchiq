# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://branchiq_user:yourpassword@localhost:5432/branchiq

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=replace-this-with-a-real-64-char-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Environment ───────────────────────────────────────────────────────────────
# "development" or "production"
# production enables: secure=True cookies, stricter logging
ENVIRONMENT=development

# ── Database Pool (optional tuning) ──────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
